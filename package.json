{
  "name": "microtags",
  "type": "module",
  "version": "0.0.12",
  "sideEffects": [
    "./example/**"
  ],
  "main": "dist/index.js",
  "files": [
    "./dist/*"
  ],
  "scripts": {
    "lint": "eslint \"./**/*.{ts,js}\"",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "npm run typecheck && esbuild --bundle ./test/index.ts | tapout",
    "test:ssr": "npx esbuild ./test/ssr.ts --bundle --format=cjs --platform=node | node",
    "test:importmap": "esbuild ./test/importmap/run.ts --bundle --platform=node --format=cjs --packages=external | node",
    "build-cjs": "esbuild src/index.ts src/render.ts src/context.ts src/util.ts --bundle --packages=external --format=cjs --keep-names --tsconfig=tsconfig.build.json --outdir=./dist --out-extension:.js=.cjs --sourcemap",
    "build-esm": "esbuild src/index.ts src/render.ts src/context.ts src/util.ts --bundle --packages=external --splitting --format=esm --metafile=dist/meta.json --keep-names --tsconfig=tsconfig.build.json --outdir=./dist --sourcemap && tsc --emitDeclarationOnly --project tsconfig.build.json --outDir dist",
    "build-esm:min": "esbuild src/index.ts src/render.ts src/context.ts src/util.ts --format=esm --keep-names --bundle --tsconfig=tsconfig.build.json --minify --out-extension:.js=.min.js --outdir=./dist --sourcemap",
    "build-example": "npm run build-html && mkdir -p ./public && rm -rf ./public/* && NODE_ENV=development vite --mode staging --base=\"/microtags\" build",
    "build-docs": "typedoc --tsconfig tsconfig.build.json ./src/index.ts",
    "build": "mkdir -p ./dist && rm -rf ./dist/* && npm run build-cjs && npm run build-esm && npm run build-esm:min",
    "build-html": "npm run --silent ssr > example/index.html",
    "size": "size-limit",
    "inject-size": "esbuild ./scripts/inject-size.ts --bundle --platform=node --format=cjs | node",
    "start": "npm run build-html && vite",
    "ssr": "esbuild ./example/ssr.ts --bundle --platform=node --format=cjs | node ",
    "toc": "markdown-toc --maxdepth 4 -i README.md",
    "preversion": "npm run lint",
    "version": "npm run toc && auto-changelog -p --template keepachangelog --breaking-pattern 'BREAKING CHANGE:' && npm run inject-size && git add CHANGELOG.md README.md",
    "postversion": "git push --follow-tags && npm publish",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./min": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.min.js"
    },
    "./render": {
      "types": "./dist/render.d.ts",
      "import": "./dist/render.js",
      "require": "./dist/render.cjs"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js",
      "require": "./dist/context.cjs"
    },
    "./util": {
      "types": "./dist/util.d.ts",
      "import": "./dist/util.js",
      "require": "./dist/util.cjs"
    }
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "alien-signals": "^3.2.1"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.1.0",
    "@substrate-system/debug": "^0.9.64",
    "@substrate-system/dom": "^0.1.13",
    "@substrate-system/tapout": "^0.0.38",
    "@substrate-system/tapzero": "^0.10.16",
    "@types/node": "^26.0.1",
    "auto-changelog": "^2.4.0",
    "browserslist": "^4.28.4",
    "esbuild": "^0.28.0",
    "eslint": "^10.6.0",
    "lightningcss": "^1.32.0",
    "markdown-toc": "^1.2.0",
    "nanotags": "^0.15.2",
    "newneostandard": "^0.14.1",
    "size-limit": "^12.1.0",
    "tap-spec": "^5.0.0",
    "typedoc": "^0.28.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.5",
    "zod": "^4.4.3"
  },
  "author": "nichoth <nichoth@nichoth.com> (https://nichoth.com)",
  "license": "SEE LICENSE IN LICENSE"
}
